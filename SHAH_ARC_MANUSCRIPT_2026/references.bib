,@ARTICLE{Kanj2024-te,
  title     = "Application of Global Lung Function Initiative Global spirometry
               reference equations across a large, multicenter pulmonary
               function lab population",
  author    = "Kanj, Amjad N and Scanlon, Paul D and Yadav, Hemang and Smith,
               William T and Herzog, Tyler L and Bungum, Aaron and Poliszuk,
               Daniel and Fick, Edward and Lee, Augustine S and Niven, Alexander
