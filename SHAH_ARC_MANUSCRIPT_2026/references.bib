,@ARTICLE{DeGroodt1988-go,
  title     = "Growth of lung and thorax dimensions during the pubertal growth
               spurt",
  author    = "DeGroodt, E G and van Pelt, W and Borsboom, G J and Quanjer, P H
               and van Zomeren, B C",
  journal   = "Eur. Respir. J.",
  publisher = "Eur Respiratory Soc",
  volume    =  1,
  number    =  2,
  pages     = "102--108",
  abstract  = "In the follow-up study of adolescents residual volume (RV), vital
               capacity (VC), closing volume (CV), thorax height and thorax
               width were measured at six month intervals over a six year
               period; 149 girls and 477 boys, whose ages ranged between 11.5
